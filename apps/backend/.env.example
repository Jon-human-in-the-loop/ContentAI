# ═══════════════════════════════════════════════════════════════════════════════
#  ContentAI — Backend Environment Variables
#  Copiá este archivo como .env y completá los valores
# ═══════════════════════════════════════════════════════════════════════════════

# ── CORE (REQUERIDO) ─────────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=https://tu-frontend.up.railway.app

# JWT — generá con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Encryption — exactamente 64 caracteres hexadecimales
# generá con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── BASE DE DATOS Y CACHE (Railway los inyecta automáticamente) ───────────────
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# REDIS_URL=redis://user:pass@host:6379

# ── IA — GENERACIÓN DE CONTENIDO ─────────────────────────────────────────────

# Anthropic Claude (REQUERIDO para generación de texto)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (para generación de imágenes)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ── REDES SOCIALES (OAuth 2.0) ────────────────────────────────────────────────
# Redirect URI a registrar en cada plataforma:
# {OAUTH_REDIRECT_BASE}/api/v1/oauth/{platform}/callback

OAUTH_REDIRECT_BASE=https://tu-backend.up.railway.app

# Meta (Instagram + Facebook)
# https://developers.facebook.com/apps/
META_APP_ID=
META_APP_SECRET=

# LinkedIn — https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# X (Twitter) — https://developer.twitter.com/en/portal/dashboard
# Scopes: tweet.read tweet.write users.read offline.access
X_CLIENT_ID=
X_CLIENT_SECRET=

# TikTok — https://developers.tiktok.com/apps/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Google Calendar — https://console.cloud.google.com/apis/credentials
# Redirect URI: {OAUTH_REDIRECT_BASE}/api/v1/calendar/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── ALMACENAMIENTO (S3 / MinIO) ───────────────────────────────────────────────
# Sin estas variables las imagenes se devuelven como base64 (no se guardan)
# Para MinIO: S3_ENDPOINT=http://tu-minio:9000  |  Para AWS S3: dejar vacio
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=contentai-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# ── VIDEO CON IA ──────────────────────────────────────────────────────────────

# Creatify Aurora — https://app.creatify.ai/dashboard → API Keys
CREATIFY_API_ID=
CREATIFY_API_KEY=

# TTS — Text to Speech (audio para videos)
# Opcion 1: Google Cloud TTS
# https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
GOOGLE_TTS_API_KEY=
# Opcion 2: ElevenLabs (voces mas naturales)
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── BILLING (Stripe) ──────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Webhook endpoint: {BACKEND_URL}/api/v1/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs — crea productos en Stripe Dashboard para cada plan
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── EMAIL (SMTP) ──────────────────────────────────────────────────────────────
# Resend: HOST=smtp.resend.com, PORT=465, USER=resend, PASS=tu-api-key
# Gmail:  HOST=smtp.gmail.com,  PORT=587, USER=tucuenta@gmail.com, PASS=app-password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ContentAI <noreply@tudominio.com>
