# ContentAI — Backend Environment Variables
# Copy this file to .env and fill in the values

# CORE
PORT=4000
FRONTEND_URL=https://your-frontend.up.railway.app

# JWT
JWT_SECRET=

# Encryption
ENCRYPTION_KEY=

# DATABASE & CACHE
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# REDIS_URL=redis://user:pass@host:6379

# AI - CONTENT GENERATION
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# SOCIAL MEDIA (OAuth 2.0)
OAUTH_REDIRECT_BASE=https://your-backend.up.railway.app
META_APP_ID=
META_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# STORAGE (S3 / MinIO)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=contentai-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# AI VIDEO
CREATIFY_API_ID=
CREATIFY_API_KEY=

# TTS
GOOGLE_TTS_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# BILLING (Stripe)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# EMAIL (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@contentai.com
